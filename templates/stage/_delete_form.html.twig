{# templates/stage/_delete_form.html.twig #}
<form method="post" action="{{ path('app_stage_delete', {'id': stage.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce stage ?');" style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ stage.id) }}">
    <button class="icon-btn delete" title="Supprimer">🗑️</button>
</form>

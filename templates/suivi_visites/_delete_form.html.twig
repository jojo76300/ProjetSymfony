<form method="post"
      action="{{ path('app_suivi_visites_delete', {'id': visite.id}) }}"
      onsubmit="return confirm('Supprimer cette visite ?');"
      style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ visite.id) }}">
    <button class="icon-btn delete">🗑️</button>
</form>

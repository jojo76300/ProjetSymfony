{# Formulaire commun new / edit #}
{{ form_start(form) }}
    <div class="form-group">
        {{ form_label(form.stage, 'Stage') }}
        {{ form_widget(form.stage, {'attr': {'class': 'select-field'}}) }}
    </div>

    <div style="display:flex; gap:1rem;">
        <div class="form-group" style="flex:1;">
            {{ form_label(form.dateVisite, 'Date de visite') }}
            {{ form_widget(form.dateVisite, {
                'attr': {'class': 'input-text', 'placeholder': 'jj/mm/aaaa'}
            }) }}
        </div>
        <div class="form-group" style="flex:1;">
            {{ form_label(form.enseignantVisiteur, 'Enseignant visiteur') }}
            {{ form_widget(form.enseignantVisiteur, {'attr': {'class': 'select-field'}}) }}
        </div>
    </div>

    <div class="form-group">
        {{ form_label(form.commentaires, 'Commentaires (optionnel)') }}
        {{ form_widget(form.commentaires, {
            'attr': {'class': 'input-text', 'style': 'height:120px;'}
        }) }}
    </div>

    <button class="btn-primary-full" style="background:#2563eb;">
        {{ button_label|default('Planifier') }}
    </button>
{{ form_end(form) }}

{% extends 'base.html.twig' %}

{% block title %}Connexion - Suivi des stages BTS SIO{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Fond de la page (légèrement grisé pour faire ressortir la carte) */
        body {
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        /* Style de la carte blanche centrale */
        .login-card {
            background: #ffffff;
            width: 100%;
            max-width: 400px;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            text-align: center;
        }

        /* Style du logo */
        .login-logo {
            max-width: 120px;
            margin-bottom: 20px;
        }

        /* Titres */
        .login-title {
            font-size: 24px;
            font-weight: 600;
            color: #111827;
            margin-bottom: 8px;
        }

        .login-subtitle {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 30px;
        }

        /* Formulaire : labels et champs */
        .form-group {
            text-align: left;
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #111827;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            font-size: 14px;
            color: #111827;
            background-color: #f3f4f6; /* Fond gris clair comme sur la maquette */
            border: 1px solid transparent;
            border-radius: 8px;
            transition: all 0.2s ease-in-out;
            box-sizing: border-box;
        }

        .form-control:focus {
            outline: none;
            border-color: #3b82f6;
            background-color: #ffffff;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
        }

        .form-control::placeholder {
            color: #9ca3af;
        }

        /* Bouton de connexion noir */
        .btn-login {
            width: 100%;
            padding: 12px;
            background-color: #030712; /* Noir très sombre */
            color: #ffffff;
            font-size: 15px;
            font-weight: 600;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 10px;
            margin-bottom: 20px;
        }

        .btn-login:hover {
            background-color: #1f2937;
        }

        /* Lien mot de passe oublié */
        .forgot-password-link {
            display: inline-block;
            font-size: 14px;
            font-weight: 500;
            color: #2563eb;
            text-decoration: none;
        }

        .forgot-password-link:hover {
            text-decoration: underline;
        }
    </style>
{% endblock %}

{% block body %}
<div class="login-card">
    
    {# 
        Note technique : Dans Symfony, les images doivent se trouver dans le dossier public/images/.
        Ici je mets votre chemin absolu comme demandé, mais idéalement remplacez le src par : "{{ asset('images/logo.png') }}"
    #}
    <img src="{{ asset('images/logo.png') }}" alt="Logo La Châtaigneraie" class="login-logo">
    
    <h1 class="login-title">Suivi des stages BTS SIO</h1>
    <p class="login-subtitle">Connectez-vous pour accéder à la plateforme</p>

    <form method="post">
        {% if error %}
            <div style="color: #dc2626; font-size: 14px; margin-bottom: 20px; text-align: left;">
                Identifiants invalides.
            </div>
        {% endif %}

        {% if app.user %}
            <div style="color: #059669; font-size: 14px; margin-bottom: 20px; text-align: left;">
                Vous êtes connecté ({{ app.user.userIdentifier }}). <a href="{{ path('app_logout') }}">Déconnexion</a>
            </div>
        {% endif %}

        <div class="form-group">
            <label for="inputEmail" class="form-label">Email</label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" placeholder="nom@exemple.fr" autocomplete="email" required autofocus>
        </div>

        <div class="form-group">
            <label for="inputPassword" class="form-label">Mot de passe</label>
            <input type="password" name="password" id="inputPassword" class="form-control" placeholder="••••••••" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="btn-login">
            Se connecter
        </button>
    </form>

    <a href="#" class="forgot-password-link">Mot de passe oublié ?</a>
</div>
{% endblock %}

{{ form_start(form) }}
    <div class="form-group">
        {{ form_label(form.classe) }}
        {{ form_widget(form.classe, {'attr': {'class': 'input-text', 'required': 'required'}}) }}
        {{ form_errors(form.classe) }}
    </div>

    <div class="form-group">
        {{ form_label(form.session) }}
        {{ form_widget(form.session, {'attr': {'class': 'input-text', 'required': 'required'}}) }}
        {{ form_errors(form.session) }}
    </div>

    <div style="display:flex; gap:1rem;">
        <div class="form-group" style="flex:1;">
            {{ form_label(form.dateDebutStageDefaut) }}
            {{ form_widget(form.dateDebutStageDefaut, {'attr': {'class': 'input-text', 'required': 'required'}}) }}
            {{ form_errors(form.dateDebutStageDefaut) }}
        </div>
        <div class="form-group" style="flex:1;">
            {{ form_label(form.dateFinStageDefaut) }}
            {{ form_widget(form.dateFinStageDefaut, {'attr': {'class': 'input-text', 'required': 'required'}}) }}
            {{ form_errors(form.dateFinStageDefaut) }}
        </div>
    </div>

    <button class="btn-primary-full">
        {{ button_label|default('Enregistrer') }}
    </button>
{{ form_end(form) }}
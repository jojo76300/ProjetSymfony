<form method="post"
      action="{{ path('app_promotion_delete', {'id': promotion.id}) }}"
      onsubmit="return confirm('Supprimer cette promotion ?');"
      style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ promotion.id) }}">
    <button class="icon-btn delete">🗑️</button>
</form>
<form method="post"
      action="{{ path('app_etudiant_delete', {'id': etudiant.id}) }}"
      onsubmit="return confirm('Voulez-vous vraiment archiver/supprimer cet étudiant ?');"
      style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etudiant.id) }}">
    <button class="icon-btn delete">🗑️</button>
</form>

{% extends 'dashboard/index.html.twig' %}

{% block title %}Ajouter un étudiant{% endblock %}

{% block body %}
<div class="modal-bg">
    <div class="modal-card">
        <div class="modal-header">
            <h2>Ajouter un étudiant</h2>
            <a href="{{ path('app_etudiant_index') }}" class="modal-close">×</a>
        </div>

        {{ form_start(form) }}
            <div class="form-group">
                {{ form_label(form.nom, 'Nom') }}
                {{ form_widget(form.nom, {'attr': {'class': 'input-text'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.prenom, 'Prénom') }}
                {{ form_widget(form.prenom, {'attr': {'class': 'input-text'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.filiere, 'Filière') }}
                {{ form_widget(form.filiere, {'attr': {'class': 'select-field'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.promotion, 'Promotion') }}
                {{ form_widget(form.promotion, {'attr': {'class': 'select-field'}}) }}
            </div>

            <button type="submit" class="btn-primary-full">
                Ajouter
            </button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
